{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@tresorerie/api": ["./packages/api/src"],
      "@tresorerie/db": ["./packages/db/src"],
      "@tresorerie/config": ["./packages/config"],
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["node_modules"]
}
